# Elasticsearch
ES_HOST=https://elasticsearch.yourdomain.com
ES_USERNAME=elastic
ES_PASSWORD=your-elasticsearch-password
ES_VERIFY_CERTS=true
ES_CA_CERT_PATH=
ES_TIMEOUT=30
ES_MAX_RETRIES=3

# Kibana
KIBANA_HOST=https://kibana.yourdomain.com
KIBANA_USERNAME=elastic
KIBANA_PASSWORD=your-elasticsearch-password
KIBANA_VERIFY_SSL=true
KIBANA_TIMEOUT=30

# Logstash
LOGSTASH_HOST=https://logstash.yourdomain.com
LOGSTASH_MONITORING_PORT=9600
LOGSTASH_VERIFY_SSL=true

# Fluent Bit (Kubernetes in-cluster)
FLUENT_BIT_NAMESPACE=logging
FLUENT_BIT_LABEL=app.kubernetes.io/name=fluent-bit
FLUENT_BIT_METRICS_PORT=2020

# Alerting: Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#elk-alerts

# Alerting: PagerDuty
PAGERDUTY_ROUTING_KEY=

# Alerting: Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=team@yourdomain.com
SMTP_PASSWORD=

# Alerting: AWS SNS
SNS_TOPIC_ARN=

# Alert thresholds
DISK_WARN_PCT=80
DISK_CRIT_PCT=90
JVM_WARN_PCT=75
JVM_CRIT_PCT=90
UNASSIGNED_SHARDS_WARN=5
UNASSIGNED_SHARDS_CRIT=10
INDEX_LATENCY_WARN_MS=50
INDEX_LATENCY_CRIT_MS=200
SEARCH_LATENCY_WARN_MS=100
SEARCH_LATENCY_CRIT_MS=500
ALERT_COOLDOWN_MINUTES=15

# Monitor service
COLLECTION_INTERVAL=60
DASHBOARD_PORT=8080
DASHBOARD_HOST=0.0.0.0
METRICS_RETENTION_HOURS=24
LOG_LEVEL=INFO
ENVIRONMENT=production
